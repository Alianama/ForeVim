# Backend Environment Configuration

# App
APP_NAME="ForeVim - VM Monitoring & Forecasting"
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security — CHANGE THESE IN PRODUCTION
SECRET_KEY=super-secret-key-change-in-production-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://forevim:forevim@postgres:5432/forevim
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Prometheus — URL dikelola via web (Prometheus Sources), bukan env
PROMETHEUS_TIMEOUT=30
METRICS_SCRAPE_INTERVAL=15

# Forecasting — on-demand via API; scheduler background default off (hemat CPU)
FORECAST_SCHEDULER_ENABLED=false
FORECAST_MAX_LOOKBACK_HOURS=336

# Alert Thresholds
ALERT_CPU_THRESHOLD=85.0
ALERT_RAM_THRESHOLD=90.0
ALERT_DISK_THRESHOLD=85.0

# Superuser (seed on first run)
FIRST_SUPERUSER_EMAIL=admin@forevim.local
FIRST_SUPERUSER_PASSWORD=ChangeMe123!

# Notifications (optional)
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
